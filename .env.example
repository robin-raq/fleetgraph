PORT=8787

# FleetGraph API auth for Ship frontend -> FleetGraph requests
FLEETGRAPH_API_KEY=replace_me
# Comma-separated allowlist for browser clients ("*" allows all)
CORS_ORIGINS=*

# Ship target configuration
SHIP_API_BASE_URL_LOCAL=http://localhost:3000
SHIP_API_TOKEN_LOCAL=replace_me

SHIP_API_BASE_URL_PROD=https://ship-app-production.up.railway.app
SHIP_API_TOKEN_PROD=replace_me
# Timeout for Ship API requests (milliseconds)
SHIP_API_TIMEOUT_MS=8000

# LLM + tracing
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true
LANGCHAIN_API_KEY=replace_me
LANGCHAIN_PROJECT=FleetGraph-MVP

# Proactive trigger
ENABLE_PROACTIVE_CRON=false
PROACTIVE_CRON=*/5 8-18 * * 1-5
# Max in-memory approvals retained before oldest is evicted
MAX_APPROVAL_RECORDS=500
